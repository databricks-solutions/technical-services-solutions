{
	"inherit_from": ["base_infapc2databricks_pyspark.json"],
	"config_variables": {
	  "ROOT_DELTA_DIR": "/root/delta",
	  "SPARK_VERSION": "13.3.x-scala2.12",
	  "USER_NAME": "USER_NAME",
	  "EMAIL_ADDRESS": "EMAIL_ADDRESS",
	  "SUCCESS_EMAIL_ADDRESS": "SUCCESS_EMAIL_ADDRESS",
	  "FAILURE_EMAIL_ADDRESS": "FAILURE_EMAIL_ADDRESS",
	  "NODE_TYPE": "i3.xlarge",
	  "TASK_PATH": "TASK_PATH",
	  "WORKFLOW_NAME_CLUSTER": "auto_scaling_cluster"
	},
	"workflow_specs": {
	  "skip_component_types": ["email", "die", "synchronize", "exception_handler", "start"],
	  "workflow_component_mapping": {
		"SESSION": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
		  "min_retry_interval_millis": 2000,
		  "retry_on_timeout": false,
		  "max_retries": 3,
		  "notebook_task": {
			"notebook_path": "/%TASK_PATH%/%MAPPING_NAME%",
			"source": "WORKSPACE"
		  }
		},
		"SUBJOB": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
		  "min_retry_interval_millis": 2000,
		  "retry_on_timeout": false,
		  "max_retries": 3,
		  "notebook_task": {
			"notebook_path": "/%TASK_PATH%/%MAPPING_NAME%",
			"source": "WORKSPACE"
		  }
		},
		"LOAD_PARAMETERS": {
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "notebook_task": {
			"notebook_path": "/%TASK_PATH%/%JOB_NAME%_params"
		  }
		},
		"WORKLET": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "spark_python_task": {
			"python_file": "/%TASK_PATH%/%COMPONENT_NAME%.py"
		  },
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%"
		},
		"SET_VARIABLE": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
		  "min_retry_interval_millis": 2000,
		  "retry_on_timeout": false,
		  "max_retries": 3,
		  "notebook_task": {
			"notebook_path": "/%TASK_PATH%/%JOB_NAME%_%COMPONENT_NAME%",
			"source": "WORKSPACE"
		  }
		},
		"COMMAND": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
		  "notebook_task": {
			"notebook_path": "/%TASK_PATH%/%JOB_NAME%_%COMPONENT_NAME%"
		  }
		},
		"DECISION": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
		  "notebook_task": {
			"notebook_path": "/%TASK_PATH%/%JOB_NAME%_%COMPONENT_NAME%"
		  }
		},
		"ASSIGNMENT": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
		  "notebook_task": {
			"notebook_path": "/%TASK_PATH%/%JOB_NAME%_%COMPONENT_NAME%"
		  }
		},
		"NESTED_CONDITION": {
		  "task_key": "%COMPONENT_NAME%",
		  "condition_task": {
			"op": "%OP%",
			"left": "%LEFT_OP%",
			"right": "%RIGHT_OP%"
		  }
		},
		"SUBJOB__SEQUENCE__": {
		  "task_key": "%COMPONENT_NAME%",
		  "description": "%DESCRIPTION%",
		  "run_job_task": {
			"job_id": 1234567890
		  }
		}
	  },
	  "default_workflow_attr": {
		"tags": {
		  "project": "migration"
		},
		"job_clusters": [
		  {
			"job_cluster_key": "%WORKFLOW_NAME_CLUSTER%",
			"new_cluster": {
			  "spark_version": "%SPARK_VERSION%",
			  "node_type_id": "%NODE_TYPE%",
			  "enable_elastic_disk": "false",
			  "data_security_mode": "SINGLE_USER",
			  "runtime_engine": "STANDARD",
			  "num_workers": 8
			}
		  }
		],
		"email_notifications": {
		  "on_start": ["%EMAIL_ADDRESS%"],
		  "on_success": ["%SUCCESS_EMAIL_ADDRESS%"],
		  "on_failure": ["%FAILURE_EMAIL_ADDRESS%"],
		  "no_alert_for_skipped_runs": false
		},
		"timeout_seconds": 86400,
		"schedule": {
		  "quartz_cron_expression": "20 30 * * * ?",
		  "timezone_id": "Europe/London",
		  "pause_status": "PAUSED"
		},
		"max_concurrent_runs": 10,
		"format": "MULTI_TASK"
	  }
	}
  }
