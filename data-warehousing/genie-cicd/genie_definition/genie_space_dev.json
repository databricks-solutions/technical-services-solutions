    "example_question_sqls": [
      {
        "id": "01f0fd3cb0541e37b9a8cb3ee3eec240",
        "question": [
          "What is the total number of customer?"
        ],
        "sql": [
          "SELECT\n",
          "  COUNT(*) AS total_customers\n",
          "FROM\n",
          "  `my_catalog`.`my_schema`.`table_example`\n",
          "WHERE\n",
          "  `c_custkey` IS NOT NULL;"
        ]
      },
      {
        "id": "01f0fd3cc01b1fa3839f30ccde15a8cb",
        "question": [
          "What is the total number of customers in each market segment?"
        ],
        "sql": [
          "SELECT\n",
          "  `c_mktsegment`,\n",
          "  COUNT(*) AS total_customers\n",
          "FROM\n",
          "  `my_catalog`.`my_schema`.`table_example`\n",
          "WHERE\n",
          "  `c_mktsegment` IS NOT NULL\n",
          "GROUP BY\n",
          "  `c_mktsegment`\n",
          "ORDER BY\n",
          "  total_customers DESC;"
        ]
      }
    ]
