#!/bin/bash
# Environment variables for Terraform Azure Unity Catalog deployment
# Copy this file to env_variables.sh and fill in your actual values
# IMPORTANT: Do not commit env_variables.sh to version control

# =============================================================================
# Azure Service Principal (for Azure resource deployment)
# =============================================================================
# Used by Terraform azurerm provider to create:
# - Storage accounts
# - Storage containers
# - Access connectors
# - RBAC role assignments
export ARM_CLIENT_ID="your-azure-sp-client-id"
export ARM_CLIENT_SECRET="your-azure-sp-secret"
export ARM_TENANT_ID="your-azure-tenant-id"
export ARM_SUBSCRIPTION_ID="your-azure-subscription-id"

# =============================================================================
# Databricks Service Principal (for Unity Catalog resources)
# =============================================================================
# Used by Terraform databricks provider to create:
# - Storage credentials (account-level)
# - Catalogs and external locations (workspace-level)
# - Grants for user groups/service principals (workspace-level)
export DATABRICKS_CLIENT_ID="your-databricks-sp-client-id"
export DATABRICKS_CLIENT_SECRET="your-databricks-sp-secret"

# =============================================================================
# How to obtain these values:
# =============================================================================
# ARM_CLIENT_ID: Azure Portal → Azure AD → App registrations → Application ID
# ARM_CLIENT_SECRET: Azure Portal → Azure AD → App registrations → Certificates & secrets → New client secret
# ARM_TENANT_ID: Azure Portal → Azure AD → Overview → Tenant ID
# ARM_SUBSCRIPTION_ID: Azure Portal → Subscriptions → Subscription ID
#
# DATABRICKS_CLIENT_ID: Databricks Account Console → User Management → Service Principals → Application ID
# DATABRICKS_CLIENT_SECRET: Databricks Account Console → User Management → Service Principals → OAuth secrets → Generate secret
#
# Required permissions:
# - Azure SP: Contributor role on Resource Group
# - Databricks SP: Account Admin + Workspace Admin on each workspace